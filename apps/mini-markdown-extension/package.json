{
  "name": "mini-markdown-extension",
  "displayName": "Mini Markdown Extension",
  "description": "Mini Markdown Extension for VS Code",
  "version": "0.1.3",
  "publisher": "KMini15",
  "repository": "https://github.com/kmini15/mini-markdown",
  "engines": {
    "vscode": "^1.80.0"
  },
  "main": "dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "miniMarkdownExtension.openPreview",
        "title": "Mini Markdown Extension: Open Preview"
      }
    ]
  },
  "scripts": {
    "dev:build:extension": "vite build --config vite.extension.config.js",
    "dev:build:open-preview": "vite build --config vite.open-preview.config.js",
    "dev:build": "npm run dev:build:extension && npm run dev:build:open-preview",
    "dev:package": "npm run dev:build && mkdir -p ./outputs && vsce package --no-dependencies --out ./outputs",
    "dev:clean": "rm -rf dist outputs"
  },
  "type": "module",
  "dependencies": {},
  "devDependencies": {
    "vite": "^8.0.12",
    "highlight.js": "^11.11.1",
    "@kmini15/mini-markdown": "^0.1.3"
  }
}
